# Server
APP_ENV=development
APP_PORT=8080

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=ledger_db
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_TIMEOUT=5s

# Logging
LOG_LEVEL=debug

# Idempotency
IDEMPOTENCY_TTL=24h

# Refund Policy
REFUND_WINDOW_DAYS=90